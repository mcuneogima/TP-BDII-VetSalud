{
  "name": "vetsalud",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Clínica Veterinaria - BD2 2026",
  "type": "module",
  "scripts": {
    "seed:mongo": "node seeds/seed_mongo.js",
    "seed:mongo:extended": "node seeds/seed_mongo.js --extended",

    "seed:redis": "node seeds/seed_redis.js",
    "seed:all": "node seeds/seed_mongo.js && node seeds/seed_redis.js",
    "start": "node app.js",
    "check": "node app.js --check",
    "seed:redis": "node ./src/seeds/seed_redis.js",
    "seed:all": "node seeds/seed_mongo.js && node seeds/seed_redis.js",
    "start": "node ./src/app.js",
    "import-csv": "node ./src/app.js --import-csv",
    "import-extended-csv": "node ./src/app.js --import-csv --extended",
    "query-11": "node ./src/app.js --monthly-income",
    "query-12": "node ./src/app.js --no-appointment-owners",
    "query-13": "node ./src/app.js --owner-abm",
    "query-14": "node ./src/app.js --new-appointment",
    "all": "node ./src/app.js --monthly-income --no-appointment-owners --owner-abm --new-appointment",
    "seed:redis:extended": "node seeds/seed_redis.js --extended",

    "seed:all": "node seeds/seed_mongo.js && node seeds/seed_redis.js",
    "seed:all:extended": "node seeds/seed_mongo.js --extended && node seeds/seed_redis.js --extended"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "mongoose": "^9.6.3",
    "redis": "^4.7.0"
  }
}